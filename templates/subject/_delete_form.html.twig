<form method="post" action="{{ path('app_subject_delete', {'id': subject.id}) }}" onsubmit="return confirm('آیا از حذف این موضوع اطمینان دارید؟');" class="m-0">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subject.id) }}">
	<button type="submit" class="btn btn-action table-btn-light text-danger">حذف</button>
</form>
