<!DOCTYPE html>
<html lang="fa" dir="rtl">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}سیستم مدیریت
			{% endblock %}
		</title>

		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
		{% block stylesheets %}{% endblock %}
	</head>
	<body class="app-body">
		{% set current_route = app.request.attributes.get('_route') %}
		{% block sidebar %}

			<header id="appTopbar" class="app-topbar d-lg-none sticky-top border-bottom bg-white" data-turbo-permanent>
				<div class="d-flex align-items-center justify-content-between px-3 py-2">
					<button type="button" class="btn btn-link text-dark p-0 lh-1" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="باز کردن منو">
						<i class="bi bi-list fs-4"></i>
					</button>
					<a href="{{ path('app_home') }}" class="text-decoration-none text-dark fw-semibold small text-truncate mx-2">مدیریت کتابخانه</a>
					<span class="flex-shrink-0" style="width: 2rem" aria-hidden="true"></span>
				</div>
			</header>

			<aside class="sidebar offcanvas-lg offcanvas offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel" data-turbo-permanent>
				<div class="offcanvas-header d-lg-none border-bottom py-3">
					<h5 class="offcanvas-title h6 mb-0" id="appSidebarLabel">منوی سیستم</h5>
					<button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#appSidebar" aria-label="بستن"></button>
				</div>
				<div class="offcanvas-body d-flex flex-column p-3">
					<a href="{{ path('app_home') }}" class="sidebar-brand d-flex align-items-center gap-2 mb-4 px-2 text-decoration-none text-dark">
						<img src="{{ asset('images/book-logo.png') }}" alt="Bookloan" width="28" height="28" class="rounded">
						<span class="fw-semibold">مدیریت کتابخانه</span>
					</a>

					<nav class="sidebar-nav flex-grow-1">
						<ul class="nav flex-column gap-1 mb-4">
							<li class="nav-item">
								<a href="{{ path('app_home') }}" class="nav-link {{ current_route == 'app_home' ? 'active' : '' }}" data-active-when="app_home">
									<i class="bi bi-house"></i>
									<span>داشبورد</span>
								</a>
							</li>
						</ul>

						<ul class="nav flex-column gap-1 mb-4">
							<li class="nav-item">
								<a href="{{ path('app_member_index') }}" class="nav-link {{ current_route starts with 'app_member' ? 'active' : '' }}" data-active-when-prefix="app_member">
									<i class="bi bi-people"></i>
									<span>اعضا</span>
								</a>
							</li>
							<li class="nav-item">
								<a href="{{ path('app_book_index') }}" class="nav-link {{ (current_route starts with 'app_book') and not (current_route starts with 'app_book_loan') ? 'active' : '' }}" data-active-when-prefix="app_book" data-active-exclude-prefix="app_book_loan">
									<i class="bi bi-book"></i>
									<span>کتاب‌ها</span>
								</a>
							</li>
							<li class="nav-item">
								<a href="{{ path('app_book_loan_index') }}" class="nav-link {{ current_route starts with 'app_book_loan' ? 'active' : '' }}" data-active-when-prefix="app_book_loan">
									<i class="bi bi-journal-arrow-up"></i>
									<span>امانات و رزروها</span>
								</a>
							</li>
						</ul>

						<ul class="nav flex-column gap-1">
							<li class="nav-item">
								<a href="{{ path('app_publisher_index') }}" class="nav-link {{ current_route starts with 'app_publisher' ? 'active' : '' }}" data-active-when-prefix="app_publisher">
									<i class="bi bi-building"></i>
									<span>ناشران</span>
								</a>
							</li>
							<li class="nav-item">
								<a href="{{ path('app_subject_index') }}" class="nav-link {{ current_route starts with 'app_subject' ? 'active' : '' }}" data-active-when-prefix="app_subject">
									<i class="bi bi-tags"></i>
									<span>موضوعات</span>
								</a>
							</li>
						</ul>
					</nav>

					{% if app.user %}
						<div class="sidebar-footer pt-3 mt-3 border-top">
							<div class="d-flex align-items-center gap-2 px-1">
								<div class="sidebar-avatar rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold">
									{{ app.user.userIdentifier|slice(0, 1)|upper }}
								</div>
								<div class="flex-grow-1 overflow-hidden">
									<div class="fw-semibold text-truncate small">{{ app.user.userIdentifier }}</div>
									<div class="text-muted text-truncate small">مدیر سیستم</div>
								</div>
								<div class="dropdown">
									<button class="btn btn-link text-muted p-0 lh-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
										<i class="bi bi-three-dots"></i>
									</button>
									<ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
										<li>
											<form action="{{ path('app_logout') }}" method="post" class="m-0" data-turbo="false">
												<input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}" data-controller="csrf-protection">
												<button type="submit" class="dropdown-item text-danger small py-1">
													<i class="bi bi-box-arrow-right me-2"></i>خروج از حساب
												</button>
											</form>
										</li>
									</ul>
								</div>
							</div>
						</div>
					{% endif %}
				</div>
			</aside>
		{% endblock %}

		<main class="{% block main_class %}app-main p-3 p-lg-4{% endblock %}" data-current-route="{{ current_route }}">
			<div class="mx-auto {% block container_class %}{% endblock %}" style="{% block container_style %}max-width: 900px{% endblock %}">
				{% for label, messages in app.flashes %}
					{% for message in messages %}
						<div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
							{{ message }}
							<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
						</div>
					{% endfor %}
				{% endfor %}

				{% block body %}{% endblock %}
			</div>
		</main>

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</body>
</html>
