{% extends 'base.html.twig' %}
{% import '_macros/table.html.twig' as table %}

{% block title %}مدیریت ناشران{% endblock %}

{% block body %}
	<div class="d-flex flex-column flex-lg-row justify-content-between align-items-stretch align-items-lg-center gap-3 mb-4">
		<h1 class="h5 text-dark mb-0">لیست ناشران</h1>
		<a href="{{ path('app_publisher_new') }}" class="btn btn-dark text-decoration-none">+ افزودن ناشر</a>
	</div>

	{{ table.open() }}
	<table class="table table-borderless align-middle mb-0 data-table">
		<thead>
			<tr>
				<th>شناسه</th>
				<th>نام ناشر</th>
				<th class="text-end">عملیات</th>
			</tr>
		</thead>
		<tbody>
			{% for publisher in publishers %}
				<tr>
					<td class="text-muted">{{ publisher.id }}</td>
					<td>{{ publisher.name }}</td>
					<td class="text-end">
						<a href="{{ path('app_publisher_edit', {'id': publisher.id}) }}" class="btn btn-sm table-btn-light py-1 text-decoration-none">ویرایش</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="3" class="text-center py-5 text-muted">هیچ ناشری ثبت نشده است.</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	{{ table.close() }}
{% endblock %}
