{% use 'bootstrap_5_layout.html.twig' %}

{% block radio_widget %}
	{% if 'loan-type-input' in attr.class|default('') %}
		<input type="radio" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %}>
	{% else %}
		{{ parent() }}
	{% endif %}
{% endblock %}

{% block choice_widget_expanded %}
	{% if 'loan-type-cards' in attr.class|default('') %}
		<div {{ block('widget_container_attributes') }}>
			{%- for child in form %}
				{% set meta = child.vars.value == 'loan'
					? {icon: 'journal-arrow-up', desc: 'تحویل فوری کتاب به عضو'}
					: {icon: 'bookmark', desc: 'نگه‌داری کتاب برای استفاده بعدی'}
				%}
				<label class="loan-type-card" for="{{ child.vars.id }}">
					{{ form_widget(child, {label: false, attr: {class: 'loan-type-input'}}) }}
					<span class="loan-type-card-icon" aria-hidden="true">
						<i class="bi bi-{{ meta.icon }}"></i>
					</span>
					<span class="loan-type-card-content">
						<span class="loan-type-card-title">{{ child.vars.label }}</span>
						<span class="loan-type-card-desc">{{ meta.desc }}</span>
					</span>
				</label>
			{% endfor -%}
		</div>
	{% else %}
		{{ parent() }}
	{% endif %}
{% endblock %}
