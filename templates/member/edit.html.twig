{% extends 'base.html.twig' %}

{% block title %}ویرایش عضو{% endblock %}

{% block body %}
	<div class="d-flex flex-column flex-lg-row justify-content-between align-items-stretch align-items-lg-center gap-3 mb-4">
		<h1 class="h5 text-dark mb-0">ویرایش عضو: {{ member.firstName }} {{ member.lastName }}</h1>
		<a href="{{ path('app_member_index') }}" class="btn btn-sm table-btn-light py-1 text-decoration-none">بازگشت به لیست</a>
	</div>

	<div class="card table-card p-3 p-lg-4">
		{{ include('member/_form.html.twig', {
			button_label: 'بروزرسانی',
			show_delete: true,
		}) }}
	</div>
{% endblock %}
