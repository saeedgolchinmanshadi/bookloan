{{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
{% import '_macros/form_actions.html.twig' as form_actions %}
<div class="row g-4 mb-4">
	<div class="col-md-6">
		{{ form_label(form.firstName) }}
		{{ form_widget(form.firstName) }}
		<div class="text-danger mt-1 small">{{ form_errors(form.firstName) }}</div>
	</div>
	<div class="col-md-6">
		{{ form_label(form.lastName) }}
		{{ form_widget(form.lastName) }}
		<div class="text-danger mt-1 small">{{ form_errors(form.lastName) }}</div>
	</div>

	<div class="col-md-6">
		{{ form_label(form.nationalCode) }}
		{{ form_widget(form.nationalCode) }}
		<div class="text-danger mt-1 small">{{ form_errors(form.nationalCode) }}</div>
	</div>
	<div class="col-md-6">
		{{ form_label(form.mobile) }}
		{{ form_widget(form.mobile) }}
		<div class="text-danger mt-1 small">{{ form_errors(form.mobile) }}</div>
	</div>
</div>

<div class="d-flex align-items-center mb-4 p-3 rounded bg-light border">
	{{ form_widget(form.isActive) }}
	{{ form_label(form.isActive) }}
</div>

{{ form_actions.footer(
	cancel_url|default(path('app_member_index')),
	button_label|default('ثبت اطلاعات'),
	show_delete|default(false) ? {
		url: path('app_member_delete', {id: member.id}),
		token_id: 'delete' ~ member.id,
		confirm: 'آیا از حذف این عضو اطمینان دارید؟',
	} : null
) }}

{{ form_end(form) }}
