<form method="post" action="{{ path('app_member_delete', {'id': member.id}) }}" onsubmit="return confirm('آیا از حذف این عضو اطمینان دارید؟');" class="m-0">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ member.id) }}">
	<button type="submit" class="btn btn-action table-btn-light text-danger">حذف</button>
</form>
