{% macro stat(label, value, icon, tone = 'default') %}
	<div class="col-sm-6 col-lg-3">
		<div class="dashboard-stat">
			<div class="dashboard-stat-icon">
				<i class="bi bi-{{ icon }}"></i>
			</div>
			<div class="dashboard-stat-value{% if tone != 'default' %} dashboard-stat-value-{{ tone }}{% endif %}">{{ value }}</div>
			<div class="dashboard-stat-label">{{ label }}</div>
		</div>
	</div>
{% endmacro %}

{% macro action(url, label, primary = false) %}
	<a href="{{ url }}" class="dashboard-action{% if primary %} dashboard-action-primary{% endif %} text-decoration-none">{{ label }}</a>
{% endmacro %}
