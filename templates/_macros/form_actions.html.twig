{% macro footer(cancel_url, submit_label, delete = null) %}
	<div class="form-actions d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center flex-wrap gap-3 gap-lg-4">
		{% if delete %}
			<div class="form-actions-delete">
				<button
					type="button"
					class="btn btn-action table-btn-light text-danger"
					data-delete-url="{{ delete.url }}"
					data-delete-token="{{ csrf_token(delete.token_id) }}"
					data-delete-confirm="{{ delete.confirm }}"
					data-action="delete-record"
				>حذف</button>
			</div>
		{% endif %}
		<div class="d-flex flex-column flex-lg-row align-items-stretch gap-2 gap-lg-3 ms-lg-auto">
			<button type="submit" class="btn btn-action btn-dark">{{ submit_label }}</button>
			<a href="{{ cancel_url }}" class="btn btn-action table-btn-light text-decoration-none">انصراف</a>
		</div>
	</div>
{% endmacro %}
